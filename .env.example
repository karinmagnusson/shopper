# ─────────────────────────────────────────────
# Pinterest OAuth (https://developers.pinterest.com)
# ─────────────────────────────────────────────
PINTEREST_CLIENT_ID=your_pinterest_client_id_here
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret_here

# ─────────────────────────────────────────────
# NextAuth.js
# Generate secret: openssl rand -base64 32
# ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_random_secret_string

# ─────────────────────────────────────────────
# Backend / API
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
SECRET_KEY=replace_with_a_random_secret_for_backend_jwt

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://shopper:shopper@localhost:5432/shopper
POSTGRES_USER=shopper
POSTGRES_PASSWORD=shopper
POSTGRES_DB=shopper

# ─────────────────────────────────────────────
# Cache (Redis)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Optional: Image/AI services
# ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# SERPAPI_KEY=...
