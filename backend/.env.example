# ─────────────────────────────────────────────
# Shopper Backend – Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Database ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/shopper

# ── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Pinterest OAuth ──────────────────────────
PINTEREST_CLIENT_ID=your_pinterest_client_id
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret
PINTEREST_REDIRECT_URI=http://localhost:3000/auth/callback

# ── JWT ─────────────────────────────────────
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Google Vision ────────────────────────────
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# ── Amazon Associates ────────────────────────
AMAZON_ASSOCIATE_TAG=your-associate-tag-20
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key

# ── Frontend ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Celery ───────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── App ──────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60
