# Pinterest API credentials
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret
PINTEREST_REDIRECT_URI=http://localhost:3000/auth/callback

# Database
DATABASE_URL=postgresql://shopper:shopper_pass@localhost:5432/shopper_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-at-least-32-characters

# Google Vision API
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# Amazon Associates
AMAZON_ASSOCIATE_TAG=your_associate_tag
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key

# App
APP_ENV=development
LOG_LEVEL=INFO
